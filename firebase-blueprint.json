{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string",
          "format": "uri"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Visit": {
      "title": "Visit",
      "description": "Log of a page visit",
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "userAgent": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "/visits/{visitId}": {
      "schema": {
        "$ref": "#/entities/Visit"
      },
      "description": "Visit logs"
    }
  }
}
